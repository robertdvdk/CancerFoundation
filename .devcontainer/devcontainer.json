// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "cancerfoundation",
	"build": {
		"context": "..",
		"dockerfile": "../Dockerfile"
	},

	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"username": "vscode",
			"installZsh": false,
			"configureZshAsDefaultShell": false,
			"installOhMyZsh": false,
			"upgradePackages": false
		}
	},

	"updateRemoteUserUID": true,
	"remoteUser": "vscode",

	"runArgs": [
    "--gpus",
    "all",
	"--shm-size",
    "32g", // Set shared memory to a high value, e.g., 32GB, for large datasets
	"--env-file",
	".devcontainer/devcontainer.env" // use this to set environment variables such as WANDB_API_KEY
	],

	// Git integration
    "mounts": [
        "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind"
    ],

	// Allow for tmux usage in the container, to run long training runs
	"postCreateCommand": "sudo uv pip install --system --no-deps -e . && pre-commit install",


	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.debugpy",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter@2025.7.0",
				"ms-toolsai.jupyter-keymap",
				"ms-toolsai.jupyter-renderers",
				"ms-toolsai.vscode-jupyter-cell-tags",
				"ms-toolsai.vscode-jupyter-slideshow",
				"mechatroner.rainbow-csv",
				"rioj7.command-variable",
				"njpwerner.autodocstring"
			],

		// ADD THIS BLOCK TO EXPLICITLY SET THE PYTHON PATH
			"settings": {
				"python.defaultInterpreterPath": "/usr/bin/python3"
			}
		}
	}
}
